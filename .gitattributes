# Force LF line endings for shell scripts and text files
* text=auto eol=lf
*.sh text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.py text eol=lf
*.conf text eol=lf
*.service text eol=lf

# Binaries
*.tar.gz binary
*.zip binary
*.gz binary
*.png binary
*.jpg binary
