# ==============================================================
# FreeCDN 环境变量配置
# 复制此文件为 .env 并按实际情况修改
# ==============================================================

# ---- 数据库配置 ----
MYSQL_ROOT_PASSWORD=freecdn_root_2026
MYSQL_DATABASE=freecdn
MYSQL_USER=freecdn
MYSQL_PASSWORD=freecdn_pass_2026

# ---- 管理台配置 ----
# 管理台 Web 访问端口
ADMIN_PORT=7788
# EdgeAPI 端口（边缘节点连接用）
API_PORT=8001

# ---- 系统配置 ----
TZ=Asia/Shanghai

# ---- 版本配置（用于 CI/CD）----
GOEDGE_VERSION=v1.3.9
FREECDN_VERSION=v0.1.0
