# ==============================================================
# FreeCDN Docker 部署环境变量配置
#
# 使用方法：
#   cp deploy/.env.example deploy/.env
#   然后修改 .env 中的密码（生产环境必须改！）
# ==============================================================

# ---- FreeCDN 版本（构建镜像时使用）----
FREECDN_VERSION=v0.1.6

# ---- MySQL 数据库 ----
# 注意：密码请使用纯字母数字（a-zA-Z0-9_），避免 ! @ # 等特殊字符
# GoEdge 的 YAML 解析器不支持引号包裹的密码值
MYSQL_ROOT_PASSWORD=freecdn_root_2026
MYSQL_DATABASE=freecdn
MYSQL_USER=freecdn
MYSQL_PASSWORD=freecdn_pass_2026
MYSQL_PORT=3306

# ---- 管理员账号 ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=FreeCDN2026!

# ---- 端口映射 ----
ADMIN_PORT=7788     # 管理后台 Web 端口（对外）
API_PORT=8003       # EdgeAPI RPC 端口（边缘节点连接用，对外）

# ---- 生产版：管理后台绑定地址 ----
# 改为 127.0.0.1 则只允许本机访问（配合 Nginx 反代使用）
ADMIN_HOST=0.0.0.0

# ---- 时区 ----
TZ=Asia/Shanghai

# ---- 边缘节点（freecdn-node 服务，使用 --profile node 启动时填写）----
# 在管理后台 -> 节点管理 -> 新建节点 -> 安装命令 中获取
API_ENDPOINTS=http://127.0.0.1:8003
NODE_ID=
NODE_SECRET=
