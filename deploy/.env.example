# ==============================================================
# FreeCDN 环境变量配置模板
# 使用方法：cp .env.example .env，然后修改 .env 中的值
# 注意：.env 文件包含真实密码，已加入 .gitignore，不要提交到 Git
# ==============================================================

# ---- 数据库配置 ----
# MySQL root 密码（仅限容器内部使用）
MYSQL_ROOT_PASSWORD=请设置强密码

# 应用数据库名
MYSQL_DATABASE=freecdn

# 应用数据库用户名
MYSQL_USER=freecdn

# 应用数据库用户密码
MYSQL_PASSWORD=请设置强密码

# ---- 管理台配置 ----
# 管理台 Web 访问端口
ADMIN_PORT=7788

# EdgeAPI gRPC 端口（边缘节点连接用）
API_PORT=8003

# 管理员用户名
ADMIN_USERNAME=admin

# 管理员初始密码（必须修改为强密码）
ADMIN_PASSWORD=请设置强密码

# ---- 系统配置 ----
TZ=Asia/Shanghai

# ---- 版本配置（用于构建）----
GOEDGE_VERSION=v1.3.9
FREECDN_VERSION=v0.11.0
