# ==============================================================
# FreeCDN 环境变量配置
# 复制此文件为 .env 并按实际情况修改：
#   cp deploy/.env.example deploy/.env
# ==============================================================

# ---- 数据库配置 ----
MYSQL_ROOT_PASSWORD=REDACTED_ROOT_PASS
MYSQL_DATABASE=freecdn
MYSQL_USER=freecdn
MYSQL_PASSWORD=REDACTED_DB_PASS
# 数据库端口（仅本机暴露，生产环境可注释掉）
MYSQL_PORT=3306

# ---- 管理台配置 ----
# 管理台 Web 访问端口
ADMIN_PORT=7788
# EdgeAPI RPC 端口（边缘节点连接用，需对节点 IP 开放）
API_PORT=8003
# 初始管理员账号（首次安装时自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REDACTED_SSH_PASS

# ---- 节点配置（可选，部署边缘节点时填写）----
# 从管理后台 -> 节点管理 -> 安装 页面获取
API_ENDPOINTS=http://127.0.0.1:8003
NODE_ID=
NODE_SECRET=

# ---- 系统配置 ----
TZ=Asia/Shanghai

# ---- 版本 ----
FREECDN_VERSION=v0.1.0
